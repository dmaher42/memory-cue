{
  "name": "memory-cue",
  "version": "1.0.0",
  "description": "Memory Cue – a PWA for reminders, notes, and study aids",
  "main": "service-worker.js",
  "scripts": {
    "start": "serve .",
    "test": "jest",
    "dev": "tailwindcss -i src/input.css -o styles/tailwind.css --watch",
    "build": "node scripts/build.mjs",
    "verify": "node scripts/verify-build.mjs",
    "check:reminders": "npm run build && node scripts/e2e-reminders-regression.mjs"
  },
  "keywords": [],
  "author": "Daniel Maher",
  "license": "ISC",
  "type": "commonjs",
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.10",
    "esbuild": "^0.24.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "playwright": "^1.56.1",
    "postcss": "^8.4.47",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.13"
  },
  "dependencies": {
    "chrono-node": "^2.9.0",
    "puppeteer": "^24.32.0"
  }
}
